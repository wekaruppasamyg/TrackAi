VITE_API_URL=http://localhost:8000/api

# MapTiler API Key for advanced vector maps
# Get your free key at: https://cloud.maptiler.com
# Required for all map pages to display (MapDashboard, NavigationView, GoogleAdminMap, UserLiveModal)
VITE_MAPTILER_KEY=your_maptiler_api_key_here

# Optional: OpenRouteService API Key for better routing
# Get a free key at: https://openrouteservice.org/dev/#/signup
# Falls back to OSRM (open routing) if not provided
VITE_ORS_API_KEY=

# Google OAuth (for authentication)
VITE_GOOGLE_CLIENT_ID=
